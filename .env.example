# === Production-style testing (Case A) — recommended defaults ===

# Embedding: local (free) | openai (paid, better quality)
EMBEDDING_PROVIDER=local

# LLM: groq (free tier, recommended) | local (extractive) | ollama (local) | openai (paid)
LLM_PROVIDER=groq

# Groq (only if LLM_PROVIDER=groq) — free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (only if LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (only if LLM_PROVIDER=ollama) — install from https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Infrastructure (docker compose)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=legacy_documents
DATABASE_URL=postgresql://legacy:legacy@localhost:5432/legacy_retrieval

# Paths
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed

# Retrieval
CHUNK_SIZE=1800
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=20
RERANK_TOP_K=10
EVIDENCE_THRESHOLD=0.3

# SEC EDGAR — REQUIRED for real Case A ingest (use your real email)
SEC_USER_AGENT=LegacyCapitalResearch your.email@company.com
